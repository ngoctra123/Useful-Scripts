FROM node:16
WORKDIR /usr/src/app
COPY package*.json ./
RUN npm install
COPY . .
EXPOSE 8080
CMD [ "node", "app.js" ]
# 1. Định nghĩa hình ảnh nền (base image): Sử dụng Node.js phiên bản 16
FROM node:16
# 2. Tạo một thư mục làm việc bên trong container (tương tự như lệnh 'cd')
# Mọi câu lệnh tiếp theo sẽ được thực thi tại đường dẫn này
WORKDIR /usr/src/app
# 3. Sao chép các tệp định nghĩa thư viện (package.json và package-lock.json) vào thư mục hiện tại
# Việc sao chép riêng các tệp này trước giúp tận dụng Docker Cache (không phải cài lại thư viện nếu code thay đổi)
COPY package*.json ./
# 4. Chạy lệnh cài đặt các thư viện (dependencies) đã liệt kê trong package.json
RUN npm install
# 5. Sao chép toàn bộ mã nguồn còn lại từ máy máy tính của bạn vào trong container
COPY . .

# 6. Thông báo rằng container sẽ lắng nghe (mở) cổng 8080 khi chạy
# Lưu ý: Lệnh này chỉ mang tính chất tài liệu, bạn vẫn cần map cổng khi chạy container
EXPOSE 8080

# 7. Lệnh mặc định để khởi chạy ứng dụng khi container bắt đầu hoạt động
# Ở đây là chạy tệp app.js bằng môi trường node
CMD [ "node", "app.js" ]
